GET {{baseUrl}}/v1/me/orgs
X-Human-Id: {{bobHumanId}}
X-Human-Email: {{bobHumanEmail}}

###
# Caller: Human (Alice)
# @name alpha_org_metadata_patch
PATCH {{baseUrl}}/v1/orgs/{{create_org_alpha.response.body.$.organization.org_id}}/metadata
Content-Type: application/json
X-Human-Id: {{aliceHumanId}}
X-Human-Email: {{aliceHumanEmail}}

{
  "metadata": {
    "public": true,
    "description": "Alpha org metadata"
  }
}

###
# Caller: Human (Alice)
# @name create_invite_bob
POST {{baseUrl}}/v1/orgs/{{create_org_alpha.response.body.$.organization.org_id}}/invites
Content-Type: application/json
X-Human-Id: {{aliceHumanId}}
X-Human-Email: {{aliceHumanEmail}}

{
  "email": "{{bobHumanEmail}}",
  "role": "member"
}

###
# Caller: Human (Alice)
# @name create_invite_bob_duplicate_should_conflict
POST {{baseUrl}}/v1/orgs/{{create_org_alpha.response.body.$.organization.org_id}}/invites
Content-Type: application/json
X-Human-Id: {{aliceHumanId}}
X-Human-Email: {{aliceHumanEmail}}

{
  "email": "{{bobHumanEmail}}",
  "role": "member"
}

###
# Caller: Human (Alice)
# @name list_org_invites
GET {{baseUrl}}/v1/orgs/{{create_org_alpha.response.body.$.organization.org_id}}/invites
X-Human-Id: {{aliceHumanId}}
X-Human-Email: {{aliceHumanEmail}}

###
# Caller: Human (Bob)
# @name list_my_invites
GET {{baseUrl}}/v1/org-invites
X-Human-Id: {{bobHumanId}}
X-Human-Email: {{bobHumanEmail}}

###
# Caller: Human (Bob)
# @name accept_invite
POST {{baseUrl}}/v1/org-invites/{{create_invite_bob.response.body.$.invite.invite_id}}/accept
X-Human-Id: {{bobHumanId}}
X-Human-Email: {{bobHumanEmail}}

###
# Alternative to `accept_invite` above. Use on a fresh pending invite.
# Caller: Human (Bob)
# @name redeem_invite
POST {{baseUrl}}/v1/org-invites/redeem
Content-Type: application/json
X-Human-Id: {{bobHumanId}}
X-Human-Email: {{bobHumanEmail}}

{
  "invite_id": "{{create_invite_bob.response.body.$.invite.invite_id}}"
}

###
# Alternative to `accept_invite` above. Invite recipient denies by deleting invite.
# Caller: Human (Bob)
# @name deny_invite
DELETE {{baseUrl}}/v1/org-invites/{{create_invite_bob.response.body.$.invite.invite_id}}
X-Human-Id: {{bobHumanId}}
X-Human-Email: {{bobHumanEmail}}

###
# Alternative to `deny_invite`: org owner revokes by deleting invite.
# Caller: Human (Alice)
# @name revoke_invite
DELETE {{baseUrl}}/v1/org-invites/{{create_invite_bob.response.body.$.invite.invite_id}}
X-Human-Id: {{aliceHumanId}}
X-Human-Email: {{aliceHumanEmail}}

###
# Caller: Human (Alice)
# @name create_org_access_key
POST {{baseUrl}}/v1/orgs/{{create_org_alpha.response.body.$.organization.org_id}}/access-keys
Content-Type: application/json
X-Human-Id: {{aliceHumanId}}
X-Human-Email: {{aliceHumanEmail}}

{
  "label": "Partner read key",
  "scopes": ["list_humans", "list_agents"],
  "expires_in_days": 30
}

###
# Caller: Human (Alice)
# @name list_org_access_keys
GET {{baseUrl}}/v1/orgs/{{create_org_alpha.response.body.$.organization.org_id}}/access-keys
X-Human-Id: {{aliceHumanId}}
X-Human-Email: {{aliceHumanEmail}}

###
# Caller: Human (Partner key)
# @name org_access_humans
GET {{baseUrl}}/v1/org-access/humans?org_name={{alphaOrgHandle}}
X-Org-Access-Key: {{create_org_access_key.response.body.$.key}}

###
# Caller: Human (Partner key)
# @name org_access_agents
GET {{baseUrl}}/v1/org-access/agents?org_name={{alphaOrgHandle}}
X-Org-Access-Key: {{create_org_access_key.response.body.$.key}}

### AGENTs Section

###
# Caller: Human (Alice) - mint bind token for Agent A
# @name create_agent_a_bind_token
POST {{baseUrl}}/v1/agents/bind-tokens
Content-Type: application/json
X-Human-Id: {{aliceHumanId}}
X-Human-Email: {{aliceHumanEmail}}

{
  "org_id": "{{create_org_alpha.response.body.$.organization.org_id}}"
}

###
# Caller: Agent bootstrap - Agent A self-onboards (this creates the agent)
# @name create_agent_a
POST {{baseUrl}}/v1/agents/bind
Content-Type: application/json

{
  "bind_token": "{{create_agent_a_bind_token.response.body.$.bind_token}}",
  "agent_id": "alpha-agent-one",
  "hub_url": "{{baseUrl}}"
}

###
# Caller: Human (Bob) - mint bind token for Agent B
# @name create_agent_b_bind_token
POST {{baseUrl}}/v1/agents/bind-tokens
Content-Type: application/json
X-Human-Id: {{bobHumanId}}
X-Human-Email: {{bobHumanEmail}}

{
  "org_id": "{{create_org_beta.response.body.$.organization.org_id}}"
}

###
# Caller: Agent bootstrap - Agent B self-onboards (this creates the agent)
# @name create_agent_b
POST {{baseUrl}}/v1/agents/bind
Content-Type: application/json

{
  "bind_token": "{{create_agent_b_bind_token.response.body.$.bind_token}}",
  "agent_id": "beta-agent-one",
  "hub_url": "{{baseUrl}}"
}

###
# Caller: Human (Bob) - mint bind token for Agent B2
# @name create_agent_b2_bind_token
POST {{baseUrl}}/v1/agents/bind-tokens
Content-Type: application/json
X-Human-Id: {{bobHumanId}}
X-Human-Email: {{bobHumanEmail}}

{
  "org_id": "{{create_org_beta.response.body.$.organization.org_id}}"
}

###
# Caller: Agent bootstrap - Agent B2 self-onboards (this creates the agent)
# @name create_agent_b2
POST {{baseUrl}}/v1/agents/bind
Content-Type: application/json

{
  "bind_token": "{{create_agent_b2_bind_token.response.body.$.bind_token}}",
  "agent_id": "beta-agent-two",
  "hub_url": "{{baseUrl}}"
}

###
# Caller: Agent (Agent A)
# @name agent_a_me_get
GET {{baseUrl}}/v1/agents/me
Authorization: Bearer {{create_agent_a.response.body.$.token}}

###
# Caller: Agent (Agent B)
# @name agent_b_me_get
GET {{baseUrl}}/v1/agents/me
Authorization: Bearer {{create_agent_b.response.body.$.token}}

###
