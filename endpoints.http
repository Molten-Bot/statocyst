{
  "metadata": {
    "public": true,
    "description": "Public agent A"
  }
}

###
# Caller: Agent (Agent B)
# @name agent_b_metadata_public
PATCH {{baseUrl}}/v1/agents/me/metadata
Content-Type: application/json
Authorization: Bearer {{create_agent_b.response.body.$.token}}

{
  "metadata": {
    "public": true,
    "description": "Public agent B"
  }
}

