@baseUrl = http://localhost:8080
@entitiesMetadataKey = local-entities-metadata-key

@aliceHumanId = alice
@aliceHumanEmail = alice@a.test
@aliceHandle = alice

@bobHumanId = bob
@bobHumanEmail = bob@b.test
@bobHandle = bob

@alphaOrgHandle = alpha-org
@betaOrgHandle = beta-org

###
# Caller: Public
# @name health
GET {{baseUrl}}/health

###
# Caller: Public
# @name openapi
GET {{baseUrl}}/openapi.yaml

###
# Caller: Public
# @name ui_config
GET {{baseUrl}}/v1/ui/config

###
# Caller: System (entities metadata key)
# @name entities_public_metadata
GET {{baseUrl}}/v1/entities/metadata?public=true
X-Entities-Metadata-Key: {{entitiesMetadataKey}}

### HUMANs Section

###
# Caller: Human (Alice)
# @name alice_me_get
GET {{baseUrl}}/v1/me
X-Human-Id: {{aliceHumanId}}
X-Human-Email: {{aliceHumanEmail}}

###
# Caller: Human (Alice)
# @name alice_me_patch
PATCH {{baseUrl}}/v1/me
Content-Type: application/json
X-Human-Id: {{aliceHumanId}}
X-Human-Email: {{aliceHumanEmail}}

{
  "handle": "{{aliceHandle}}"
}

###
# Caller: Human (Alice)
# @name alice_me_metadata_patch
PATCH {{baseUrl}}/v1/me/metadata
Content-Type: application/json
X-Human-Id: {{aliceHumanId}}
X-Human-Email: {{aliceHumanEmail}}

{
  "metadata": {
    "public": true,
    "testing": "Alice profile"
  }
}

###
# Caller: Human (Bob)
# @name bob_me_get
GET {{baseUrl}}/v1/me
X-Human-Id: {{bobHumanId}}
X-Human-Email: {{bobHumanEmail}}

###
# Caller: Human (Bob)
# @name bob_me_patch
PATCH {{baseUrl}}/v1/me
Content-Type: application/json
X-Human-Id: {{bobHumanId}}
X-Human-Email: {{bobHumanEmail}}

{
  "handle": "{{bobHandle}}"
}

###
# Caller: Human (Bob)
# @name bob_me_metadata_patch
PATCH {{baseUrl}}/v1/me/metadata
Content-Type: application/json
X-Human-Id: {{bobHumanId}}
X-Human-Email: {{bobHumanEmail}}

{
  "metadata": {
    "public": true,
    "description": "Bob profile"
  }
}

