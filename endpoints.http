###
# Caller: Agent (bound token)
# @name agent_me_get
GET {{baseUrl}}/v1/agents/me
Authorization: Bearer {{redeem_bind_token.response.body.$.token}}

###
# Caller: Agent (bound token)
# @name agent_me_patch
PATCH {{baseUrl}}/v1/agents/me
Content-Type: application/json
Authorization: Bearer {{redeem_bind_token.response.body.$.token}}

{
  "handle": "alpha-runtime-agent",
  "metadata": {
    "public": true,
    "description": "Runtime-updated by agent /v1/agents/me"
  }
}

###
# Caller: Agent (bound token)
# @name agent_me_metadata_patch
PATCH {{baseUrl}}/v1/agents/me/metadata
Content-Type: application/json
Authorization: Bearer {{redeem_bind_token.response.body.$.token}}

{
  "metadata": {
    "public": true,
    "description": "Runtime-updated by agent /v1/agents/me/metadata"
  }
}

###
