# Local server settings
STATOCYST_ADDR=:8080
HUMAN_AUTH_PROVIDER=dev
STATOCYST_UI_DEV_MODE=true
STATOCYST_HEADLESS_MODE=false

# Local dev login identity (used by / login page in dev auth mode)
DEV_LOGIN_HUMAN_ID=your-name
DEV_LOGIN_HUMAN_EMAIL=you-name@example.com
DEV_LOGIN_AUTO=true

# Super-admin identities.
SUPER_ADMIN_REVIEW_MODE=true
SUPER_ADMIN_EMAILS=your-name@example.com
SUPER_ADMIN_DOMAINS=example.com

# Optional
BIND_TOKEN_TTL_MINUTES=15
STATOCYST_STATE_BACKEND=memory
STATOCYST_QUEUE_BACKEND=memory
# strict (default) or degraded (fallback to memory while exposing dependency errors in /health)
STATOCYST_STORAGE_STARTUP_MODE=strict

# S3 state backend (set STATOCYST_STATE_BACKEND=s3)
# STATOCYST_STATE_S3_ENDPOINT=http://localhost:9000
# STATOCYST_STATE_S3_BUCKET=statocyst-state
# STATOCYST_STATE_S3_REGION=us-east-1
# STATOCYST_STATE_S3_PREFIX=statocyst-state
# STATOCYST_STATE_S3_PATH_STYLE=true

# S3 queue backend (set STATOCYST_QUEUE_BACKEND=s3)
# STATOCYST_QUEUE_S3_ENDPOINT=http://localhost:9000
# STATOCYST_QUEUE_S3_BUCKET=statocyst-queue
# STATOCYST_QUEUE_S3_REGION=us-east-1
# STATOCYST_QUEUE_S3_PREFIX=statocyst-queue
# STATOCYST_QUEUE_S3_PATH_STYLE=true
