{
  "gateway": {
    "bind": "lan",
    "port": 18789,
    "mode": "local",
    "auth": {
      "mode": "password",
      "password": "${OPENCLAW_GATEWAY_PASSWORD}"
    },
    "controlUi": {
      "dangerouslyDisableDeviceAuth": true,
      "allowInsecureAuth": true,
      "dangerouslyAllowHostHeaderOriginFallback": true
    }
  },
  "agents": {
    "defaults": {
      "skipBootstrap": true,
      "model": {
        "primary": "openrouter/auto"
      },
      "models": {
        "anthropic/claude-opus-4-5": {
          "alias": "Opus"
        },
        "anthropic/claude-sonnet-4-5": {
          "alias": "Sonnet"
        }
      },
      "workspace": "/mnt/workspace",
      "sandbox": {
        "mode": "off"
      },
      "memorySearch": {
        "provider": "local",
        "fallback": "none",
        "query": {
          "hybrid": {
            "enabled": true,
            "vectorWeight": 0.7,
            "textWeight": 0.3
          }
        },
        "cache": {
          "enabled": true,
          "maxEntries": 50000
        }
      }
    }
  },
  "tools": {
    "exec": {
      "security": "allowlist",
      "safeBins": [
        "jq",
        "grep",
        "cut",
        "sort",
        "uniq",
        "head",
        "tail",
        "tr",
        "wc",
        "git",
        "gh",
        "auggie",
        "claude",
        "codex"
      ],
      "safeBinTrustedDirs": [
        "/usr/local/bin"
      ],
      "safeBinProfiles": {
        "auggie": {},
        "claude": {},
        "codex": {},
        "cut": {},
        "gh": {},
        "git": {},
        "grep": {},
        "head": {},
        "jq": {},
        "sort": {},
        "tail": {},
        "tr": {},
        "uniq": {},
        "wc": {}
      }
    },
    "web": {
      "search": {
        "provider": "brave",
        "maxResults": 5,
        "timeoutSeconds": 30
      }
    }
  },
  "skills": {
    "load": {
      "extraDirs": [
        "/home/moltenbot/.openclaw/skills",
        "/mnt/skills"
      ]
    }
  },
  "cron": {
    "enabled": true,
    "store": "/mnt/workspace/.openclaw-state/cron/jobs.json",
    "maxConcurrentRuns": 2,
    "sessionRetention": "2h",
    "runLog": {
      "maxBytes": "2mb",
      "keepLines": 1024
    }
  },
  "browser": {
    "enabled": true,
    "defaultProfile": "browserless",
    "remoteCdpTimeoutMs": 2000,
    "remoteCdpHandshakeTimeoutMs": 4000,
    "profiles": {
      "browserless": {
        "cdpUrl": "http://browser:3000",
        "color": "#00AA00"
      }
    }
  }
}
