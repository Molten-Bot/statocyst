{
  "cases": [
    {
      "name": "health_ok",
      "method": "GET",
      "path": "/health",
      "expected_status": 200,
      "required_json_paths": ["status"],
      "expected_json_values": {
        "status": "ok"
      }
    },
    {
      "name": "me_unauthorized",
      "method": "GET",
      "path": "/v1/me",
      "expected_status": 401,
      "expected_error": "unauthorized",
      "required_json_paths": ["error", "message"]
    },
    {
      "name": "me_authorized_shape",
      "method": "GET",
      "path": "/v1/me",
      "headers": {
        "X-Human-Id": "alice",
        "X-Human-Email": "alice@a.test"
      },
      "expected_status": 200,
      "required_json_paths": [
        "human.human_id",
        "human.handle",
        "onboarding.handle_required"
      ],
      "expected_json_values": {
        "onboarding.handle_required": true
      }
    },
    {
      "name": "org_create_blocked_before_onboarding",
      "method": "POST",
      "path": "/v1/orgs",
      "headers": {
        "X-Human-Id": "alice",
        "X-Human-Email": "alice@a.test"
      },
      "body": {
        "handle": "alpha",
        "display_name": "Alpha"
      },
      "expected_status": 409,
      "expected_error": "onboarding_required"
    },
    {
      "name": "org_create_after_onboarding",
      "setup": "alice_handle_confirmed",
      "method": "POST",
      "path": "/v1/orgs",
      "headers": {
        "X-Human-Id": "alice",
        "X-Human-Email": "alice@a.test"
      },
      "body": {
        "handle": "alpha",
        "display_name": "Alpha"
      },
      "expected_status": 201,
      "required_json_paths": [
        "organization.org_id",
        "organization.handle",
        "membership.membership_id"
      ],
      "expected_json_values": {
        "organization.handle": "alpha"
      }
    },
    {
      "name": "publish_queued_with_trust",
      "setup": "trusted_agents",
      "method": "POST",
      "path": "/v1/messages/publish",
      "headers": {
        "Authorization": "Bearer __TOKEN_A__"
      },
      "body": {
        "to_agent_uuid": "__AGENT_UUID_B__",
        "content_type": "text/plain",
        "payload": "fixture-ping"
      },
      "expected_status": 202,
      "required_json_paths": ["ok", "result.message_id", "result.status", "result.accepted_at", "result.idempotent_replay", "message_id", "status", "accepted_at", "idempotent_replay"],
      "expected_json_values": {
        "ok": true,
        "result.status": "queued",
        "result.idempotent_replay": false,
        "status": "queued",
        "idempotent_replay": false
      }
    },
    {
      "name": "publish_dropped_without_trust",
      "setup": "agents_no_trust",
      "method": "POST",
      "path": "/v1/messages/publish",
      "headers": {
        "Authorization": "Bearer __TOKEN_A__"
      },
      "body": {
        "to_agent_uuid": "__AGENT_UUID_B__",
        "content_type": "text/plain",
        "payload": "fixture-ping"
      },
      "expected_status": 202,
      "required_json_paths": ["ok", "result.status", "result.reason", "status", "reason"],
      "expected_json_values": {
        "ok": true,
        "result.status": "dropped",
        "result.reason": "no_trust_path",
        "status": "dropped",
        "reason": "no_trust_path"
      }
    },
    {
      "name": "agent_capabilities_unauthorized",
      "method": "GET",
      "path": "/v1/agents/me/capabilities",
      "expected_status": 401,
      "expected_error": "unauthorized"
    },
    {
      "name": "agent_me_metadata_update_unauthorized",
      "method": "PATCH",
      "path": "/v1/agents/me/metadata",
      "body": {
        "metadata": {
          "public": false
        }
      },
      "expected_status": 401,
      "expected_error": "unauthorized"
    },
    {
      "name": "agent_me_metadata_update_with_agent_token",
      "setup": "trusted_agents",
      "method": "PATCH",
      "path": "/v1/agents/me/metadata",
      "headers": {
        "Authorization": "Bearer __TOKEN_A__"
      },
      "body": {
        "metadata": {
          "public": false
        }
      },
      "expected_status": 200,
      "required_json_paths": ["ok", "result.agent.agent_uuid", "result.agent.metadata.public", "agent.agent_uuid", "agent.metadata.public"],
      "expected_json_values": {
        "ok": true,
        "result.agent.metadata.public": false,
        "agent.metadata.public": false
      }
    },
    {
      "name": "agent_runtime_publish_rejects_human_headers",
      "method": "POST",
      "path": "/v1/messages/publish",
      "headers": {
        "X-Human-Id": "alice",
        "X-Human-Email": "alice@a.test"
      },
      "body": {
        "to_agent_uuid": "11111111-1111-1111-1111-111111111111",
        "content_type": "text/plain",
        "payload": "hello"
      },
      "expected_status": 401,
      "expected_error": "unauthorized"
    },
    {
      "name": "agent_runtime_pull_rejects_human_headers",
      "method": "GET",
      "path": "/v1/messages/pull?timeout_ms=0",
      "headers": {
        "X-Human-Id": "alice",
        "X-Human-Email": "alice@a.test"
      },
      "expected_status": 401,
      "expected_error": "unauthorized"
    },
    {
      "name": "human_control_rejects_agent_token",
      "setup": "trusted_agents",
      "method": "GET",
      "path": "/v1/me",
      "headers": {
        "Authorization": "Bearer __TOKEN_A__"
      },
      "expected_status": 401,
      "expected_error": "unauthorized"
    }
  ]
}
